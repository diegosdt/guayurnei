<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        body { display: flex; justify-content: center; align-items: center; min-height: 100vh; background: linear-gradient(120deg, #1f3a6c, #1d273b); margin:0; color:#fff; font-family: 'Segoe UI', sans-serif; }
        .box { background: rgba(20,30,50,.82); padding: 2rem; border-radius: 12px; max-width: 420px; width: 100%; box-shadow: 0 12px 30px rgba(0,0,0,0.5); }
        h1 { margin-bottom: 1rem; text-align: center; }
        label { display:block; margin: 1rem 0 .3rem; font-weight: 600; }
        input { width:100%; padding:.7rem .8rem; border:1px solid #345; border-radius: 8px; background: rgba(255,255,255,0.1); color:#fff; }
        button { width:100%; margin-top:16px; padding:.8rem; border:none; background:#f4a546; border-radius:10px; font-weight:700; color:#1a2333; cursor:pointer; }
        p.msg { margin-top: 1rem; text-align:center; color:#ffc1c1; }
        a.switch { display:block; margin-top:1rem; text-align:center; color:#9fc7ff; }
    </style>
</head>
<body>
<div class="box">
    <h1>Registro</h1>
    <form method="post" action="/register">
        <label>Usuario</label>
        <input type="text" name="username" autocomplete="username" required>
        <label>Contraseña</label>
        <input type="password" name="password" autocomplete="new-password" required>
        <button type="submit">Registrarse</button>
    </form>
    <% if (error) { %>
    <p class="msg"><%= error %></p>
    <% } %>
    <a class="switch" href="/login">¿Ya tienes cuenta? Inicia sesión</a>
</div>
</body>
</html>